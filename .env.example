# ── Mailgun credentials ───────────────────────────────────────────────────────
# Obtain an API key at https://app.mailgun.com/settings/api_security
MAILGUN_API_KEY=your_mailgun_api_key_here

# Your Mailgun sending domain (e.g. mg.yourdomain.com)
MAILGUN_DOMAIN=mg.yourdomain.com

# Sender address (must be authorised in your Mailgun domain)
FROM_EMAIL=alerts@yourdomain.com

# Recipient address
TO_EMAIL=recipient@yourdomain.com

# Optional: override the default email subject line
# EMAIL_SUBJECT=CAD/USD Daily Alert
