# ── SendGrid credentials ──────────────────────────────────────────────────────
# Obtain a free API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Sender address (must be verified in your SendGrid account)
FROM_EMAIL=alerts@yourdomain.com

# Recipient address
TO_EMAIL=recipient@yourdomain.com

# Optional: override the default email subject line
# EMAIL_SUBJECT=CAD/USD Daily Alert
